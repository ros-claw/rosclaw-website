# ROSClaw 批量导入工具环境变量配置
# 复制此文件为 .env 并填入你的 API Key

# 必需：ROSClaw Admin API Key（用于直接发布，跳过审核）
# 可从 Vercel 环境变量或管理员处获取
ADMIN_API_KEY=your_admin_api_key_here

# 可选：百炼 LLM API Key（用于智能分析 MCP Tools）
# 如需自动提取 MCP Tools，请配置此 Key
BAILIAN_API_KEY=your_bailian_api_key_here

# 可选：GitHub Personal Access Token（提高 API 速率限制）
# 无 Token 时每小时限 60 次请求，有 Token 时每小时 5000 次
GITHUB_TOKEN=your_github_token_here
