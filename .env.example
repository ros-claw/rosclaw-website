# Bailian (阿里云百炼) API Configuration
BAILIAN_API_KEY=sk-your-api-key-here

# Optional: Use different model
# BAILIAN_MODEL=qwen-turbo

# For production deployment
# Set to true to skip API routes (static export mode)
# NEXT_STATIC_EXPORT=false

# Supabase public connection values
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only Registry administration values
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ROSCLAW_ADMIN_EMAILS=admin@example.com
ADMIN_API_KEY=your-automation-only-admin-key
